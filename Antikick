--// 1. SILENT BYPASS CORE
local mt = getrawmetatable(game)
local oldNamecall = mt.__namecall
local oldIndex = mt.__index
setreadonly(mt, false)

mt.__namecall = newcclosure(function(self, ...)
    local method = getnamecallmethod()
    local args = {...}
    if method == "Kick" or method == "kick" then return nil end
    if method == "PostAsync" or method == "RequestAsync" then
        if tostring(args[1]):find("discord") or tostring(args[1]):find("webhook") then return nil end
    end
    if method == "FireServer" then
        local n = self.Name:lower()
        if n:find("log") or n:find("cheat") or n:find("anticheat") then return nil end
    end
    return oldNamecall(self, ...)
end)

mt.__index = newcclosure(function(self, key)
    if not checkcaller() then
        if key == "WalkSpeed" or key == "JumpPower" then return 16 end
    end
    return oldIndex(self, key)
end)
setreadonly(mt, true)

