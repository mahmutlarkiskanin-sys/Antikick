local function ShowKickWarning()
    local notification = Instance.new("Hint", workspace)
    notification.Text = "Security Alert: A kick attempt has been intercepted and bypassed."
    task.wait(4)
    notification:Destroy()
end

local mt = getrawmetatable(game)
local oldNamecall = mt.__namecall
setreadonly(mt, false)
mt.__namecall = newcclosure(function(self, ...)
    local method = getnamecallmethod()
    if method == "Kick" or method == "kick" or method == "Disconnect" then 
        task.spawn(ShowKickWarning)
        return nil 
    end
    return oldNamecall(self, ...)
end)
setreadonly(mt, true)

