local function AntiKick()
    local mt = getrawmetatable(game)
    local oldNamecall = mt.__namecall
    setreadonly(mt, false)
    mt.__namecall = newcclosure(function(self, ...)
        local method = getnamecallmethod()
        if method == "Kick" or method == "kick" or method == "Disconnect" then
            return nil 
        end
        return oldNamecall(self, ...)
    end)
    setreadonly(mt, true)
end
pcall(AntiKick)

local function CreateAnchor()
    local targetCF = CFrame.new(-410.2, 19.2, 63.1)
    local refPart = Instance.new("Part", workspace)
    refPart.Name = "StablePart_???"
    refPart.Size = Vector3.new(4, 0.5, 4)
    refPart.CFrame = targetCF
    refPart.Anchored = true
    refPart.CanCollide = true
    refPart.Color = Color3.fromRGB(255, 255, 255)
    refPart.Material = Enum.Material.SmoothPlastic
end
CreateAnchor()

local function ApplyXray()
    for _, v in pairs(workspace:GetDescendants()) do
        if v:IsA("BasePart") and not v:IsDescendantOf(lp.Character) then
            v.Transparency = 0.5
            v.CanCollide = true
        end
    end
end
ApplyXray()

local jerkActive = true 
local jerkAngle = 0
runService.Stepped:Connect(function()
    if jerkActive and lp.Character then
        local rS = lp.Character:FindFirstChild("Right Shoulder", true) or lp.Character:FindFirstChild("RightShoulder", true)
        if rS and rS:IsA("Motor6D") then
            jerkAngle = jerkAngle + 0.35 
            local hit = math.sin(jerkAngle) * 0.6
            rS.C0 = CFrame.new(1, 0.1, 0) * CFrame.Angles(0, 0, hit - 1.4)
        end
    end
end)

